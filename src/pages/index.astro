---
import Layout from '../layouts/Layout.astro';
import ScheduleCRUD from '../components/ScheduleCRUD.jsx';
---

<Layout title="Kitty Kate's Care Hub 🐾">
  <div class="text-center py-10">
    <h1 class="text-5xl font-extrabold text-indigo-600 tracking-tight drop-shadow-sm mb-4">
      Kitty Kate's Care Hub 🐾
    </h1>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto">
      The ultimate dashboard to manage feeding times, portions, and special care notes for Kitty Kate. Built with love!
    </p>
  </div>

  <div class="mt-8">
    <ScheduleCRUD client:load />
  </div>

  <Footer />
</Layout>
